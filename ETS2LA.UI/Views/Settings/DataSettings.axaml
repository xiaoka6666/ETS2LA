<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views.Settings"
             xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
             x:Class="ETS2LA.UI.Views.Settings.DataSettingsPage"
             x:DataType="views:DataSettingsPage">
    <StackPanel>
        <Grid ColumnDefinitions="500,*">
        <StackPanel Grid.Column="0" Spacing="20" Margin="20">

            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="强制基础地图名称" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ForceBaseMapName}" Classes="primary-toggle" AutomationProperties.Name="Force Base Map Name, so far only necessary for RusMap, requires restart" />
                </Grid>
                <TextBlock Text="某些模组实现了额外地图，如 japan.mbd 或 russia.mbd。如果发现模组无法正常加载，请尝试启用此选项。RusMap 需要此项。" FontSize="12" Classes="Description" />
                <StackPanel IsVisible="{Binding BaseMapNameNeedsRestart}">
                    <TextBlock Text="警告：需要重启 ETS2LA 才能使此更改生效。" FontSize="12" Classes="Warning" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="强制加载地图" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ForceMapLoad}" Classes="primary-toggle" AutomationProperties.Name="Force Map Load on game startup, requires restart" />
                </Grid>
                <TextBlock Text="强制 ETS2LA 在游戏启动时加载地图。这可以解决 game.log.txt 文件不在 ETS2LA 预期位置的问题。" FontSize="12" Classes="Description" />
                <StackPanel IsVisible="{Binding ForceMapLoadNeedsRestart}">
                    <TextBlock Text="警告：需要重启 ETS2LA 才能使此更改生效。" FontSize="12" Classes="Warning" />
                </StackPanel>
            </StackPanel>

            <Separator />

            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="数据保真度" />
                    <TextBlock Text="调整游戏数据的细节级别。较高的值使用更多 RAM，但包含更多信息。所有级别驾驶体验相同。" FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding DataFidelityOptions}" 
                        SelectedIndex="{Binding SelectedDataFidelityOption}" 
                        SelectionChanged="OnDataFidelityChanged"
                        AutomationProperties.Name="Data Fidelity selection, high values use more RAM">

                    <TabStrip.Styles>
                        <Style Selector="TabStripItem" x:DataType="views:TabStripItemHandler">
                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                        </Style>
                    </TabStrip.Styles>

                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="70" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
                <StackPanel Spacing="3" IsVisible="{Binding ShowRamWarning}">
                    <TextBlock Text="由于 RAM 不足，您无法使用某些数据保真度选项。高需要 16GB，极致需要 20GB。" FontSize="12" Classes="Warning" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowLowInfo}">
                    <TextBlock Text="此设置仅加载游戏中地图可见的道路和交叉口。它会丢弃所有其他信息。" FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowMediumInfo}">
                    <TextBlock Text="此设置丢弃冗余信息，同时保留大多数细节对象（如标牌）。不包括游戏中地图未显示的任何道路/交叉口。" FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowHighInfo}">
                    <TextBlock Text="此设置丢弃冗余信息，同时保留大多数细节对象（如标牌）。包括所有隐藏道路和 AI 专用道路。" FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowExtremeInfo}">
                    <TextBlock Text="此设置包含所有可用数据，其中大部分是冗余的。" FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowExtremeWarning}">
                    <TextBlock Text="警告：极致模式会消耗大量 RAM，预计使用超过 10GB。" FontSize="12" Classes="Warning" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="曲线质量" />
                    <TextBlock Text="调整用于路径规划和可视化的曲线质量。默认情况下与游戏一致。" FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding CurveQualityOptions}" 
                        SelectedIndex="{Binding SelectedCurveQualityOption}" 
                        SelectionChanged="OnCurveQualityChanged"
                        AutomationProperties.Name="Curve quality">

                    <TabStrip.Styles>
                        <Style Selector="TabStripItem" x:DataType="views:TabStripItemHandler">
                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                        </Style>
                    </TabStrip.Styles>
                    
                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="115" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </StackPanel>
        </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>