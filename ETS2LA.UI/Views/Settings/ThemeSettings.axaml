<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views.Settings"
             xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
             x:Class="ETS2LA.UI.Views.Settings.ThemeSettings"
             x:DataType="views:ThemeSettings">
    <Grid ColumnDefinitions="300,*">
        <StackPanel Grid.Column="0" Spacing="12" Margin="20">
            <TextBlock Text="颜色主题" />
            <ComboBox Name="ThemeCombobox" SelectedIndex="0" SelectionChanged="OnThemeChanged" AutomationProperties.Name="Window Theme">
                <ComboBoxItem Content="系统" />
                <ComboBoxItem Content="浅色" />
                <ComboBoxItem Content="深色" />
            </ComboBox>
            <TextBlock Text="强调色" />
            <ComboBox Name="AccentColorCombobox" SelectedIndex="20" SelectionChanged="OnAccentColorChanged" AutomationProperties.Name="Window Accent Color">
                <ComboBoxItem Content="系统" />
                <ComboBoxItem Content="中性" />
                <ComboBoxItem Content="番茄红" />
                <ComboBoxItem Content="红色" />
                <ComboBoxItem Content="宝石红" />
                <ComboBoxItem Content="绯红" />
                <ComboBoxItem Content="粉色" />
                <ComboBoxItem Content="梅紫" />
                <ComboBoxItem Content="紫色" />
                <ComboBoxItem Content="紫罗兰" />
                <ComboBoxItem Content="鸢尾紫" />
                <ComboBoxItem Content="靛蓝" />
                <ComboBoxItem Content="蓝色" />
                <ComboBoxItem Content="青色" />
                <ComboBoxItem Content="蓝绿" />
                <ComboBoxItem Content="翡翠绿" />
                <ComboBoxItem Content="绿色" />
                <ComboBoxItem Content="草绿" />
                <ComboBoxItem Content="古铜" />
                <ComboBoxItem Content="金色" />
                <ComboBoxItem Content="橙色" />
                <ComboBoxItem Content="琥珀" />
                <ComboBoxItem Content="黄色" />
                <ComboBoxItem Content="青柠" />
                <ComboBoxItem Content="薄荷" />
                <ComboBoxItem Content="天蓝" />
            </ComboBox>
        </StackPanel>
    </Grid>
</UserControl>