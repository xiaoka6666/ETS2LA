<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views.Settings"
             x:Class="ETS2LA.UI.Views.Settings.UserSettingsView"
             x:DataType="views:UserSettingsView">
    <Grid ColumnDefinitions="450,*">
        <StackPanel Grid.Column="0" Spacing="20" Margin="20">
        
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="启用匿名遥测" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsTelemetryEnabled}" Classes="primary-toggle" AutomationProperties.Name="Enable Anonymous Telemetry, needs restart" />
                </Grid>
                <TextBlock Text="匿名遥测帮助我们改进 ETS2LA，让我们了解用户的系统规格、崩溃情况和其他使用数据。您的数据无法与任何个人信息关联。" FontSize="12" Classes="Description" />
            </StackPanel>

            <StackPanel Spacing="12" IsVisible="{Binding NeedsRestart}">
                <TextBlock Text="此值需要重启才能生效。" FontSize="12" Classes="Warning" />
            </StackPanel>

            <StackPanel Spacing="12">
                <HyperlinkButton Content="查看公开遥测数据" NavigateUri="https://telemetry.ets2la.com/public-dashboards/17f53fce4749475c8efcab181b1306f3" FontSize="12" AutomationProperties.Name="View Public Telemetry" />
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>