<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views.Settings"
             xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
             xmlns:ctxt="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia"
             xmlns:mdctl="clr-namespace:Markdown.Avalonia.Controls;assembly=Markdown.Avalonia"
             x:Class="ETS2LA.UI.Views.Settings.Updates"
             x:DataType="views:Updates">
    <Border Padding="20">
        <StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="24">
                <StackPanel VerticalAlignment="Center" Spacing="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="当前版本：" />
                        <TextBlock Classes="Highlight" Text="{Binding CurrentVersion}"/>
                        <TextBlock Text="." />
                    </StackPanel>
                    <Button Content="检查更新" Width="150" HorizontalAlignment="Left" Click="OnCheckForUpdatesClick" AutomationProperties.Name="检查更新"/>
                </StackPanel>

                <TextBlock VerticalAlignment="Center" Text="→" FontSize="20" Classes="Description" IsVisible="{Binding IsUpdateAvailable}"/>

                <StackPanel VerticalAlignment="Center" IsVisible="{Binding IsUpdateAvailable}" Spacing="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="最新版本：" />
                        <TextBlock Classes="Highlight" Text="{Binding LatestVersion}"/>
                    </StackPanel>
                    <Button Content="安装并重启" Width="150" HorizontalAlignment="Left" Click="OnInstallAndRestartClick" AutomationProperties.Name="Install Update and Restart"/>
                </StackPanel>
            </StackPanel>

            <husk:MarkdownViewer
                Markdown="{Binding ReleaseNotes}"
                IsVisible="{Binding IsUpdateAvailable}"
                Margin="0 10 0 0"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{StaticResource ControlForegroundBrush}"
                FontFamily="{StaticResource Geist}"
                FontSize="13"
            >
                <husk:MarkdownViewer.Styles>
                    <Style Selector="DockPanel.Markdown.List.Item">
                        <Setter Property="Margin" Value="2,2,0,2" />
                    </Style>
                </husk:MarkdownViewer.Styles>
            </husk:MarkdownViewer>
        </StackPanel>
    </Border>
</UserControl>