<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views"
             xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="ETS2LA.UI.Views.DashboardView"
             x:DataType="views:DashboardView">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14">
            <!-- If someone can tell me how to do this without MaxWidth then please do so... -->
            <UniformGrid Columns="2" ColumnSpacing="14"
                MaxWidth="{Binding Extent.Width, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                <husk:Card Padding="16">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock FontSize="18" FontFamily="{StaticResource Geist}">
                                欢迎回来，<Span Classes="Highlight">匿名用户</Span>！
                            </TextBlock>
                        </Grid>

                        <WrapPanel ItemSpacing="16">
                            <StackPanel Spacing="4">
                                <husk:Tag>
                                    <TextBlock Text="当前版本" FontSize="12" />
                                </husk:Tag>
                                <TextBlock Text="{Binding CurrentRelease}" FontSize="13" Margin="6 0 0 0"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <husk:Tag>
                                    <TextBlock Text="在线用户" FontSize="12" />
                                </husk:Tag>
                                <TextBlock Text="-" FontSize="13" Margin="6 0 0 0"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <husk:Tag>
                                    <TextBlock Text="24小时用户" FontSize="12" />
                                </husk:Tag>
                                <TextBlock Text="-" FontSize="13" Margin="6 0 0 0"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </husk:Card>
            </UniformGrid>

            <UniformGrid Columns="2" ColumnSpacing="14"
                MaxWidth="{Binding Extent.Width, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                <husk:Card Padding="16">
                    <Grid RowDefinitions="Auto,*" RowSpacing="16">
                        <StackPanel Grid.Row="0" Spacing="4" VerticalAlignment="Top">
                            <TextBlock Text="支持与更新" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock HorizontalAlignment="Stretch" Text="关注开发进展并获取支持。请注意，此版本的 ETS2LA 仍在开发中。如果发现错误，请报告！" Classes="Description" FontSize="13"/>
                        </StackPanel>
                        <WrapPanel Grid.Row="1" ItemSpacing="8" VerticalAlignment="Bottom">
                            <Button Content="文档" Click="OpenDocumentation" AutomationProperties.Name="Open the ETS2LA Documentation in Browser, button"/>
                            <Button Content="GitHub" Click="OpenGitHub" AutomationProperties.Name="Open the ETS2LA GitHub in Browser, button"/>
                            <Button Content="Discord" Click="OpenDiscord" AutomationProperties.Name="Open the ETS2LA Discord in Browser, button"/>
                        </WrapPanel>
                    </Grid>
                </husk:Card>
            </UniformGrid>

            <UniformGrid Columns="2" ColumnSpacing="14"
                MaxWidth="{Binding Extent.Width, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                <husk:Card Padding="16">
                    <Grid RowDefinitions="Auto,*" RowSpacing="16">
                        <StackPanel Grid.Row="0" Spacing="4" VerticalAlignment="Top">
                            <TextBlock Text="赞助我们" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock HorizontalAlignment="Stretch" Text="您的支持帮助我持续开发 ETS2LA！收到的捐赠越多，我就能投入越多时间改进项目。感谢您！" Classes="Description" FontSize="13"/>
                        </StackPanel>
                        <WrapPanel Grid.Row="1" ItemSpacing="8" VerticalAlignment="Bottom">
                            <Button Content="赞助开发" Click="OpenDonate" Classes="Primary" AutomationProperties.Name="Open Tumppi066's Donation Page in Browser, button"/>
                        </WrapPanel>
                    </Grid>
                </husk:Card>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
